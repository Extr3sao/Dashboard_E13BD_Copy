# DB Connection (Uncomment and fill)
# DB_TYPE=postgres  # or oracle, sqlserver, etc.
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mydatabase
# DB_USER=myuser
# DB_PASSWORD=mypassword

# Oracle profiles
# DEFAULT_PROFILE=E13BD
# CONNECTIONS_FILE=config\Cadena_conexions.txt
# Required for Oracle connections: the app forces python-oracledb Thick mode.
# ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient

# Secret Management Recommendation
# Use a Vault or Secret Manager in production.
# AI Integration
# Set to 'true' to include the AI-generated Diagnostics section in the report.
# Requires an active AI assistant configuration.
AI_IMPROVEMENT_PLAN=false

# Local SQLite stores. If unset, the app uses %LOCALAPPDATA%\OracleAudit on Windows.
# INTERNAL_DB_PATH=C:\Users\your-user\AppData\Local\OracleAudit\internal.db
# AUTOMATION_DB_PATH=C:\Users\your-user\AppData\Local\OracleAudit\automation.db

# Initial data bootstrap. Enabled by default when running run.ps1.
# Set to 0 to start with empty local stores.
# BOOTSTRAP_INITIAL_DATA=1

# Optional private bootstrap JSON. Keep *.local.json files out of Git.
# BOOTSTRAP_DATA_PATH=resources\bootstrap\initial_data.local.json

# SMTP mail delivery for automation jobs.
# These values can also be configured from the app in Notificacions / MailConfigView.
# SMTP_HOST=smtp.example.local
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=oracle-audit@example.com
# SMTP_DEFAULT_RECIPIENTS=
